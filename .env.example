# ── Site ──────────────────────────────────────────────────────
# Public URL of the deployed site (no trailing slash).
# Used for canonical URLs, Open Graph, sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── SMTP (Nodemailer) — contact form emails ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_TO_EMAIL=your-email@gmail.com

# ── Admin panel login ─────────────────────────────────────────
# Use a STRONG password — this guards your project editor.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=use-a-strong-unique-password
# Any long random string — signs the admin session cookie.
# Generate one:  openssl rand -base64 48
AUTH_SECRET=change-this-to-a-long-random-string
